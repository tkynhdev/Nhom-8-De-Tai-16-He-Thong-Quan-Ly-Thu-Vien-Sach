#!/bin/sh

MAVEN_PROJECTBASEDIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
WRAPPER_DIR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper"
MAVEN_VERSION="3.9.9"
MAVEN_DIST_DIR="$WRAPPER_DIR/dists/apache-maven-$MAVEN_VERSION"
MAVEN_CMD="$MAVEN_DIST_DIR/bin/mvn"
MAVEN_ZIP="$WRAPPER_DIR/dists/apache-maven-$MAVEN_VERSION-bin.zip"
MAVEN_URL="https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/$MAVEN_VERSION/apache-maven-$MAVEN_VERSION-bin.zip"

if [ ! -x "$MAVEN_CMD" ]; then
  mkdir -p "$WRAPPER_DIR/dists"
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$MAVEN_URL" -o "$MAVEN_ZIP"
  elif command -v wget >/dev/null 2>&1; then
    wget -q "$MAVEN_URL" -O "$MAVEN_ZIP"
  else
    echo "Cannot download Maven: curl or wget is required." >&2
    exit 1
  fi
  unzip -q "$MAVEN_ZIP" -d "$WRAPPER_DIR/dists"
fi

exec "$MAVEN_CMD" "$@"
